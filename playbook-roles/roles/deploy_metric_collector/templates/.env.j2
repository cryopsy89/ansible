LOG_LEVEL={{ log_level }}
AMQP_URI={{ amqp_uri }}
AMQP_EXCHANGE=exchange.{{project_id}}.{{project_name}}
AMQP_AGENT_ID=metric-collector-{{ collector_name | default(project_name) | trim }}
UID=metric-collector-{{ collector_name | default(project_name) | trim }}
AMQP_AGENT_NAME="Metric Collector for {{project_name}} on {{ http_api_host }}"
AMQP_REQUEST_QUEUE=from-agent
AMQP_METRICS_QUEUE=metrics
AMQP_REPLY_QUEUE_PREFIX=
HTTP_API_HOST={{ http_api_host }}
HTTP_API_PORT={{ http_api_port }}
AGENT_PORT={{ agent_port }}
METRIC_COLLECTOR_IP={{ metric_collector_ip }}
METRIC_COLLECTOR_PORT={{ metric_collector_port }}
#AGENT_CERT_PATH=certificate.pem
#AGENT_KEY_PATH=certificate.key
ETCD_ENDPOINTS={{ etcd_endpoints }}

{% if extra_env is defined and extra_env | trim %}
{{ extra_env }}
{% endif %}

